# Port the Node server listens on inside the container
PORT=3000

# production | development
NODE_ENV=production

# Exact origin allowed for Socket.io CORS in production, e.g. https://chat.example.com
# Leave blank in local/dev testing (falls back to permissive same-origin behavior).
ALLOWED_ORIGIN=

# How long (ms) a room may sit with only one occupant — either nobody has
# joined yet, or a peer disconnected mid-call — before it's auto-expired.
# Default: 10 minutes.
ROOM_TTL_MS=600000

# Optional TURN server. If TURN_URL is left blank, the app runs STUN-only
# (Google STUN servers are always included). Required for reliable connections
# across carrier-grade NAT (most mobile networks).
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
