# Port the Node server listens on inside the container
PORT=3000

# production | development
NODE_ENV=production

# Exact origin allowed for Socket.io CORS in production, e.g. https://chat.example.com
# Leave blank in local/dev testing (falls back to permissive same-origin behavior).
ALLOWED_ORIGIN=

# How long (ms) a room may sit with only one occupant — either nobody has
# joined yet, or a peer disconnected mid-call — before it's auto-expired.
# Default: 10 minutes.
ROOM_TTL_MS=600000

# Optional TURN server. If TURN_URL is left blank, the app runs STUN-only
# (Google STUN servers are always included). TURN is required for reliable
# connections when both peers are behind carrier-grade NAT or a restrictive
# firewall, where STUN alone can't establish a direct path. TURN_URL may be a
# single URL or a comma-separated list (e.g. turn:host:3478,turns:host:5349).
TURN_URL=

# Preferred: a shared secret for coturn's time-limited use-auth-secret mode —
# the server derives a fresh, short-lived username/credential per call instead
# of using a long-lived shared password. Must match `static-auth-secret` in
# coturn/turnserver.conf. Leave blank to use static credentials below instead.
TURN_SECRET=

# Fallback: static long-term credentials (simpler; fine for a trusted/
# self-hosted deployment). Ignored if TURN_SECRET is set.
TURN_USERNAME=
TURN_CREDENTIAL=
