# Sample coturn configuration for secureChat's optional TURN relay.
# Copy to coturn/turnserver.conf, edit the values below, then start with:
#   docker compose --profile turn up -d
#
# TURN is only needed as a fallback for peers behind carrier-grade NAT where
# direct/STUN connectivity fails. Without it, the app still works via STUN
# alone on simpler networks.

listening-port=3478
fingerprint

# Must match the host/IP clients will reach this container on.
# realm=turn.example.com

# --- Static long-term credentials (simplest option) -------------------------
# Set matching values in .env as TURN_USERNAME / TURN_CREDENTIAL.
# NOTE: these are visible to any connecting browser client (sent in the
# iceServers payload). Fine for a trusted/self-hosted deployment; for an
# internet-facing production deployment prefer the time-limited
# use-auth-secret mode below instead.
lt-cred-mech
user=changeme:changeme

# --- Time-limited credentials (recommended for production) ------------------
# Uncomment and set a strong shared secret; have server.js/coturn compute
# short-lived HMAC username/password pairs instead of static creds.
# use-auth-secret
# static-auth-secret=REPLACE_WITH_A_LONG_RANDOM_SECRET

# Relay port range — must also be opened on the host firewall / cloud
# security group, or TURN relay will silently fail to establish media.
min-port=49152
max-port=49200

# No verbose/access logging — keep this aligned with the app's zero-log policy.
no-cli
simple-log
log-file=stdout
verbose=false
