# Sample coturn configuration for Ghostline's optional TURN relay.
# Copy to coturn/turnserver.conf, edit the values below, then start with:
#   docker compose --profile turn up -d
#
# TURN is only needed as a fallback for peers behind carrier-grade NAT where
# direct/STUN connectivity fails. Without it, the app still works via STUN
# alone on simpler networks.

listening-port=3478
fingerprint

# Must match the host/IP clients will reach this container on.
# realm=turn.example.com

# --- Time-limited credentials (recommended for production) ------------------
# server.js automatically switches to this mode whenever TURN_SECRET is set
# in .env — it derives a fresh, short-lived HMAC username/password pair per
# call instead of using a long-lived shared password. Set the SAME secret
# here and in .env as TURN_SECRET.
use-auth-secret
static-auth-secret=REPLACE_WITH_A_LONG_RANDOM_SECRET

# --- Static long-term credentials (simpler alternative) ----------------------
# Only used if TURN_SECRET is left unset in .env — set matching values here
# and in .env as TURN_USERNAME / TURN_CREDENTIAL instead. NOTE: these are
# visible to any connecting browser client (sent in the iceServers payload),
# so prefer the time-limited mode above for an internet-facing deployment.
# lt-cred-mech
# user=changeme:changeme

# Relay port range — must also be opened on the host firewall / cloud
# security group, or TURN relay will silently fail to establish media.
min-port=49152
max-port=49200

# No verbose/access logging — keep this aligned with the app's zero-log policy.
no-cli
simple-log
log-file=stdout
verbose=false
